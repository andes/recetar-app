    "moment": "^2.25.3",
    "pdfmake": "^0.1.65",
    "pdfmake-unicode": "0.0.1",
    "pdfmake-wrapper": "^2.0.0",
    "qrcode": "^1.5.4",
    "rxjs": "~6.5.4",
