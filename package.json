{
  "name": "prescription-validator",
  "version": "0.0.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "ng": "ng",
    "start": "node server.js",
    "build": "ng build",
    "build:dev": "ng build --configuration=dev",
    "heroku-postbuild": "ng build --configuration=dev",
    "test": "ng test",
    "lint": "eslint -c .eslintrc.js --ext .ts .",
    "lint:fix": "eslint -c .eslintrc.js --ext .ts . --fix",
    "pwa": "ng build --configuration=production && start \"RecetAR\" cmd /c node server.js & start \"ngrok\" cmd /c ngrok http 8080",
    "pwa:dev": "ng build --configuration=dev && start \"RecetAR\" cmd /c node server.js & start \"ngrok\" cmd /c ngrok http 8080",
    "pwa:local": "ng build --configuration=local && start \"RecetAR\" cmd /c node server.js & start \"ngrok\" cmd /c ngrok http 8080"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.25",
