{
    "$schema": "./node_modules/@angular/service-worker/config/schema.json",
    "index": "/index.html",
    "assetGroups": [
        {
            "name": "app-shell",
            "installMode": "prefetch",
            "updateMode": "prefetch",
            "resources": {
                "files": [
                    "/index.html",
                    "/*.css",
                    "/*.js",
                    "/assets/**"
                ]
            }
        }
    ]
}
